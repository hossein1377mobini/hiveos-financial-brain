# ── HiveOS Environment ──────────────────────────────────────────
# ADR-0008: on-premise default. Copy to .env and edit.
# ────────────────────────────────────────────────────────────────

# HTTP bind address (0.0.0.0 = all interfaces)
HIVEOS_HOST=0.0.0.0

# HTTP port (default: 8080)
HIVEOS_PORT=8080

# Data persistence directory (container path, mounted as volume)
HIVEOS_DATA_DIR=/data

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
